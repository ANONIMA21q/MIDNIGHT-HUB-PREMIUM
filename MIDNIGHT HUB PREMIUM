-- varre os GUIs e troca uma cor exata por outra (bg / texto / stroke)
local function scanRecolor(roots, oldCol, newCol, mode)
    if oldCol == newCol then return end
    for _, root in ipairs(roots) do
        if root then
            for _, o in ipairs(root:GetDescendants()) do
                if mode == "bg" then
                    pcall(function() if o:IsA("GuiObject") and o.BackgroundColor3 == oldCol then o.BackgroundColor3 = newCol end end)
                elseif mode == "text" then
                    pcall(function() if (o:IsA("TextLabel") or o:IsA("TextButton") or o:IsA("TextBox")) and o.TextColor3 == oldCol then o.TextColor3 = newCol end end)
                elseif mode == "stroke" then
                    pcall(function() if o:IsA("UIStroke") and o.Color == oldCol then o.Color = newCol end end)
                end
            end
        end
    end
end

setAccent = function(col)
    C.Accent = col; C.Accent2 = lighten(col, 0.35); DRAW = col
    for _, fn in ipairs(radioRefreshers) do pcall(fn) end
    for _, s in ipairs(sliderFills) do
        pcall(function() s.fill.BackgroundColor3 = col end)
        pcall(function() s.grad.Color = ColorSequence.new(col, C.Accent2) end)
    end
    for name, t in pairs(tabBtns) do
        pcall(function() t.bar.BackgroundColor3 = col end)
        if name == activeTab then pcall(function() t.txt.TextColor3 = col end) end
    end
    pcall(function() fovStroke.Color = col end)
    for _, d in pairs(espCache) do
        pcall(function() d.hl.FillColor = col end)
        pcall(function() d.tracer.BackgroundColor3 = col end)
        for _, l in pairs(d.bones) do pcall(function() l.BackgroundColor3 = col end) end
    end
end

-- FUNDO separado: recolore janela, barras, cards e linhas (tons derivados)
setBgColor = function(col)
    local oldBG, oldBar, oldCard, oldHover, oldLine = C.BG, C.Bar, C.Card, C.Hover, C.Line
    C.BG    = col
    C.Bar   = lighten(col, 0.06)
    C.Card  = lighten(col, 0.12)
    C.Hover = lighten(col, 0.18)
    C.Line  = lighten(col, 0.24)
    local roots = { main }
    scanRecolor(roots, oldBG, C.BG, "bg")
    scanRecolor(roots, oldBar, C.Bar, "bg")
    scanRecolor(roots, oldCard, C.Card, "bg")
    scanRecolor(roots, oldHover, C.Hover, "bg")
    scanRecolor(roots, oldLine, C.Line, "bg")
    scanRecolor(roots, oldLine, C.Line, "stroke")
end

-- TEXTO separado: recolore só os textos claros (os "Dim" continuam apagados)
setTextColor = function(col)
    local old = C.Text; if old == col then return end
    C.Text = col
    scanRecolor({ main }, old, col, "text")
end

-- ESP separado (independente do destaque)
setEspColor = function(col)
    DRAW = col
    for _, d in pairs(espCache) do
        pcall(function() d.hl.FillColor = col end)
        pcall(function() d.tracer.BackgroundColor3 = col end)
        for _, l in pairs(d.bones) do pcall(function() l.BackgroundColor3 = col end) end
    end
end

-- FOV separado
setFovColor = function(col)
    pcall(function() fovStroke.Color = col end)
end

setSharp = function(v)
    for _, e in ipairs(uiCorners) do
        pcall(function() e.c.CornerRadius = v and UDim.new(0, 0) or UDim.new(0, e.r) end)
    end
end

-- aplica um preset de painel inteiro (as "variáveis de painel")
applyStyle = function(name)
    local s = STYLES[name]; if not s then return end
    if setBgColor   then setBgColor(s.bg) end
    if setTextColor then setTextColor(s.text) end
    if setAccent    then setAccent(s.accent) end
    if setEspColor  then setEspColor(s.accent) end
    if setFovColor  then setFovColor(s.accent) end
    CFG.Sharp = s.sharp
    if setSharp then setSharp(s.sharp) end
    for _, fn in ipairs(radioRefreshers) do pcall(fn) end
    if requestSave then requestSave() end
    if notify then notify("Estilo aplicado: " .. name, "ok") end
end

-- baixa dados de uma URL tentando vários métodos de executor
local function httpFetch(url)
    local tries = {
        function() return game:HttpGet(url) end,
        function() return game:HttpGetAsync(url) end,
        function()
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if req then local r = req({ Url = url, Method = "GET" }); return r and (r.Body or r.body) end
        end,
    }
    for _, fn in ipairs(tries) do
        local ok, res = pcall(fn)
        if ok and type(res) == "string" and #res > 0 then return res end
    end
    return nil
end

-- o link já é direto pra uma imagem? (.png/.jpg/.jpeg/.webp)
local function looksDirectImage(u)
    u = u:lower()
    return (u:find("%.png") or u:find("%.jpe?g") or u:find("%.webp")) ~= nil
end
-- acha a imagem real dentro do HTML de uma página (Pinterest, etc.)
local function extractImageFromHtml(html)
    if type(html) ~= "string" then return nil end
    -- Pinterest guarda em i.pinimg.com
    local pin = html:match('https://i%.pinimg%.com/[%w%p]-%.jpg') or html:match('https://i%.pinimg%.com/[%w%p]-%.png')
    if pin then return pin end
    -- meta og:image (padrão em quase todo site)
    local og = html:match('og:image"%s*content="([^"]+)"') or html:match('content="([^"]+)"%s*property="og:image"')
    if og then return (og:gsub("&amp;", "&")) end
    -- qualquer .jpg/.png https solto
    local any = html:match('https://[%w%p]-%.jpg') or html:match('https://[%w%p]-%.png')
    return any
end

setBgImage = function(input, statusLbl)
    input = tostring(input or ""):gsub("^%s+", ""):gsub("%s+$", "")
    CFG.BgImage = input
    local function setStat(t, c) if statusLbl then statusLbl.Text = t; statusLbl.TextColor3 = c or C.Dim end end
    if input == "" then if bgImage then bgImage.Image = ""; bgImage.Visible = false end; setStat("Vazio."); return end
    -- ID numérico do Roblox: caminho mais fácil/confiável (não precisa baixar nada)
    if tonumber(input) then
        local id = input
        if not bgImage then setStat("Erro interno.", C.Red); return end
        bgImage.Image = "rbxassetid://" .. id
        bgImage.ImageTransparency = CFG.BgTransparency
        bgImage.Visible = true
        pcall(function() main.BackgroundTransparency = 0 end)
        setStat("Carregando ID " .. id .. "...", C.Dim)
        -- se o ID for de Decal (não carrega direto), cai pro rbxthumb (renderiza qualquer asset)
        task.delay(1.2, function()
            if bgImage and bgImage.Visible and not bgImage.IsLoaded then
                bgImage.Image = "rbxthumb://type=Asset&id=" .. id .. "&w=420&h=420"
                setStat("✔ Aplicado via thumb (ID " .. id .. ")", C.Green)
            else
                setStat("✔ Imagem aplicada! (ID " .. id .. ")", C.Green)
            end
        end)
        if requestSave then requestSave() end
        if notify then notify("Imagem de fundo aplicada", "ok") end
        return
    end
    local content
    if input:sub(1, 13) == "rbxassetid://" then
        content = input
    elseif input:sub(1, 4) == "http" then
        if not (writefile and getcustomasset) then
            setStat("Executor sem writefile/\ngetcustomasset. Use um ID.", C.Red); return
        end
        local imgUrl = input
        -- se for link de PÁGINA (Pinterest etc.), acha a imagem real dentro dela
        if not looksDirectImage(imgUrl) then
            setStat("Procurando a imagem na\npágina...", C.Dim)
            local page = httpFetch(imgUrl)
            local found = page and extractImageFromHtml(page)
            if found then imgUrl = found
            else setStat("Não achei a imagem na página.\nUse o link direto (.jpg/.png).", C.Red); return end
        end
        setStat("Baixando imagem...", C.Dim)
        local data = httpFetch(imgUrl)
        if not data then setStat("Falha ao baixar a imagem.\nTente um ID do Roblox.", C.Red); return end
        local ext = imgUrl:lower():find("%.jpe?g") and "jpg" or "png"
        local fname = "midnight_bg." .. ext
        local ok = pcall(function()
            writefile(fname, data)
            content = getcustomasset(fname)
        end)
        if not ok or not content then setStat("Falha ao salvar a imagem.", C.Red); return end
    else
        if not getcustomasset then setStat("Executor sem getcustomasset.", C.Red); return end
        local ok = pcall(function() content = getcustomasset(input) end)
        if not ok or not content then setStat("Arquivo não achado no\nexecutor (pasta workspace).", C.Red); return end
    end
    if content and bgImage then
        bgImage.Image = content
        bgImage.ImageTransparency = CFG.BgTransparency
        bgImage.Visible = true
        -- garante que a imagem fique visível atrás do conteúdo
        pcall(function() main.BackgroundTransparency = 0 end)
        setStat("✔ Imagem aplicada!", C.Green)
        if requestSave then requestSave() end
        if notify then notify("Imagem de fundo aplicada", "ok") end
    else
        setStat("Não foi possível aplicar.", C.Red)
    end
end


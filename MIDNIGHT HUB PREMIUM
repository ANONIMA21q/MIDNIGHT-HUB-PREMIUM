    local track = Instance.new("Frame", h)
    track.Size = UDim2.new(1, 0, 0, 8); track.Position = UDim2.new(0, 0, 0, 24); track.BackgroundColor3 = C.Card; track.BorderSizePixel = 0; corner(track, 4)
    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3 = C.Accent; fill.Size = UDim2.new(0, 0, 1, 0); fill.BorderSizePixel = 0; corner(fill, 4)
    local fgrad = gradient(fill, C.Accent, C.Accent2, 0)
    table.insert(sliderFills, { fill = fill, grad = fgrad })
    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.fromOffset(14, 14); knob.AnchorPoint = Vector2.new(0.5, 0.5); knob.Position = UDim2.new(0, 0, 0.5, 0)
    knob.BackgroundColor3 = C.White; knob.BorderSizePixel = 0; corner(knob, 7)
    local function fmt(v) if decimals and decimals > 0 then local m = 10 ^ decimals; return math.floor(v * m + 0.5) / m end return math.floor(v + 0.5) end
    local function update()
        local pct = math.clamp((CFG[key] - minV) / (maxV - minV), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0); knob.Position = UDim2.new(pct, 0, 0.5, 0)
        val.Text = tostring(fmt(CFG[key])) .. "/" .. tostring(fmt(maxV))
    end
    update()
    table.insert(sliderUpdaters, update)
    table.insert(searchItems, { obj = h, label = tostring(label):lower(), tab = buildTab })
    local dragging = false
    local function setX(x)
        local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local v = minV + (maxV - minV) * rel
        if decimals and decimals > 0 then local m = 10 ^ decimals; v = math.floor(v * m + 0.5) / m else v = math.floor(v + 0.5) end
        CFG[key] = v; update(); if onChange then onChange(v) end
        if requestSave then requestSave() end
    end
    track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; setX(i.Position.X) end end)
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then setX(i.Position.X) end end)
    return h
end

local function Dropdown(parent, label, key, options, order)
    local h = Instance.new("Frame", parent)
    h.Size = UDim2.new(1, 0, 0, 44); h.LayoutOrder = order or 0; h.BackgroundTransparency = 1
    local lbl = Instance.new("TextLabel", h)

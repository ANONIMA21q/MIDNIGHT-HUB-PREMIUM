local function Radio(parent, label, key, order, onChange)
    local row = Instance.new("TextButton", parent)
    row.Size = UDim2.new(1, 0, 0, 22); row.LayoutOrder = order or 0
    row.BackgroundTransparency = 1; row.AutoButtonColor = false; row.Text = ""
    local circle = Instance.new("Frame", row)
    circle.Size = UDim2.fromOffset(16, 16); circle.Position = UDim2.new(0, 0, 0.5, -8)
    circle.BackgroundColor3 = CFG[key] and C.Accent or C.Off; circle.BorderSizePixel = 0; corner(circle, 8)
    local ring = stroke(circle, CFG[key] and C.Accent or C.Line, 1.5, 0)
    local dotIn = Instance.new("Frame", circle)
    dotIn.Size = UDim2.fromOffset(6, 6); dotIn.Position = UDim2.new(0.5, -3, 0.5, -3)
    dotIn.BackgroundColor3 = C.White; dotIn.BorderSizePixel = 0; corner(dotIn, 3); dotIn.Visible = CFG[key]
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -26, 1, 0); lbl.Position = UDim2.new(0, 26, 0, 0)
    lbl.BackgroundTransparency = 1; lbl.Text = label; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 13
    lbl.TextColor3 = CFG[key] and C.Text or C.Dim; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local function refresh()
        local on = CFG[key]
        tw(circle, {BackgroundColor3 = on and C.Accent or C.Off}, 0.12)
        tw(ring, {Color = on and C.Accent or C.Line}, 0.12)
        dotIn.Visible = on
        tw(lbl, {TextColor3 = on and C.Text or C.Dim}, 0.12)
    end
    row.MouseButton1Click:Connect(function()
        CFG[key] = not CFG[key]; refresh()
        if onChange then onChange(CFG[key]) end
        if requestSave then requestSave() end
    end)
    table.insert(radioRefreshers, refresh)
    table.insert(searchItems, { obj = row, label = tostring(label):lower(), tab = buildTab })
    return row
end


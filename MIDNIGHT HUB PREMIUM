local function hideESP(d)
    d.hl.Enabled = false; d.bb.Enabled = false; d.tracer.Visible = false
    for _, l in pairs(d.bones) do l.Visible = false end
end

local lastTextUpd = 0
RunService.RenderStepped:Connect(function()
    if not AccessGranted or not CFG.ESP then for _, d in pairs(espCache) do hideESP(d) end; return end
    if not Camera then Camera = workspace.CurrentCamera end
    if not Camera then return end
    local vp = Camera.ViewportSize
    local now = os.clock()
    local doText = (now - lastTextUpd) > 0.08   -- nome/vida atualizam ~12x/s (o resto é todo frame)
    if doText then lastTextUpd = now end
    for plr, d in pairs(espCache) do
        hideESP(d)
        local char = plr.Character; if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
        local head = char:FindFirstChild("Head")
        if not hum or not hrp or hum.Health <= 0 then continue end
        if CFG.TeamCheck and plr.Team and LP.Team and plr.Team == LP.Team then continue end
        if CFG.Box then d.hl.Adornee = char; d.hl.Enabled = true end
        if (CFG.Name or CFG.Health) and head then
            d.bb.Adornee = head; d.bb.Enabled = true
            if doText then
                if CFG.Name then
                    local t = plr.Name
                    if CFG.Distance then t = t .. "  [" .. math.floor((Camera.CFrame.Position - hrp.Position).Magnitude) .. "m]" end
                    d.nameL.Text = t; d.nameL.Visible = true
                else d.nameL.Visible = false end
                if CFG.Health then
                    local pct = hum.Health / math.max(hum.MaxHealth, 1)
                    d.hpL.Text = "HP " .. math.floor(hum.Health); d.hpL.TextColor3 = healthColor(pct); d.hpL.Visible = true
                else d.hpL.Visible = false end
            end
        end
        local rp, on = Camera:WorldToViewportPoint(hrp.Position)
        if on and rp.Z > 0 then
            if CFG.Tracer then setLine(d.tracer, Vector2.new(vp.X / 2, vp.Y), Vector2.new(rp.X, rp.Y), 2); d.tracer.Visible = true end
            if CFG.Skeleton then
                local bset = char:FindFirstChild("UpperTorso") and R15Bones or R6Bones
                for i, bn in ipairs(bset) do
                    local a = char:FindFirstChild(bn[1]); local b = char:FindFirstChild(bn[2])
                    if a and b then
                        local pa, va = Camera:WorldToViewportPoint(a.Position)
                        local pb, vb = Camera:WorldToViewportPoint(b.Position)
                        if va and vb and pa.Z > 0 and pb.Z > 0 then
                            setLine(d.bones[i], Vector2.new(pa.X, pa.Y), Vector2.new(pb.X, pb.Y), 2); d.bones[i].Visible = true
                        end
                    end
                end
            end
        end
    end
end)


                            elseif CFG.IncludeNPC then table.insert(list, part) end
                        end
                    end
                end
            end
            aimCache = list
        else aimCache = {} end
        task.wait(0.3)
    end
end)

-- calcula o alvo atual (fora do hook) e escreve na tabela compartilhada
RunService.RenderStepped:Connect(function()
    S.minLen   = CFG.MinRayLen
    S.maxOrigin= CFG.MaxOriginDist
    S.wallbang = CFG.Wallbang
    S.on       = AccessGranted and CFG.Aim          -- controla o HOOK do silent
    local wantTarget = AccessGranted and (CFG.Aim or CFG.AimLock)  -- alvo p/ silent E/OU aim lock
    if not wantTarget then S.target = nil; return end
    if not Camera then Camera = workspace.CurrentCamera end
    if not Camera then return end
    local mouse = UIS:GetMouseLocation()  -- FOV a partir do mouse
    local inFov, inFovDist = nil, CFG.FOV
    local onScr, onScrDist = nil, math.huge
    for _, part in ipairs(aimCache) do
        if part and part.Parent then
            local sp, on = Camera:WorldToViewportPoint(part.Position)
            if on and sp.Z > 0 then
                local mag = (Vector2.new(sp.X, sp.Y) - mouse).Magnitude
                if mag < inFovDist then inFovDist = mag; inFov = part end
                if mag < onScrDist then onScrDist = mag; onScr = part end
            end
        end
    end
    S.target = inFov or (CFG.FallbackScreen and onScr or nil)
end)

-- AIM LOCK: trava a câmera no alvo (estilo Midnight antigo)
RunService.RenderStepped:Connect(function()
    if not (AccessGranted and CFG.AimLock) then return end
    -- se "segurar botão direito" ligado, só trava enquanto o botão direito está pressionado
    if CFG.AimLockHold and not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
    local tgt = S.target
    if not (tgt and tgt.Parent) then return end
    if not Camera then Camera = workspace.CurrentCamera end
    if not Camera then return end
    local from = Camera.CFrame.Position
    local goal = CFrame.new(from, tgt.Position)
    local a = math.clamp(CFG.AimLockSmooth or 0.5, 0.05, 1)
    Camera.CFrame = Camera.CFrame:Lerp(goal, a)
end)

-- instala o hook UMA vez (guardado por genv)
local hookOK = (getrawmetatable and setreadonly and newcclosure and getnamecallmethod)
local alreadyHooked = genv and genv.MID_HOOK
if hookOK and not alreadyHooked then
    if genv then genv.MID_HOOK = true end
    local ok = pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        local old = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if S.on and method == "Raycast" and self == workspace then
                local tgt = S.target
                if tgt and tgt.Parent then
                    local cam = workspace.CurrentCamera
                    if cam then
                        local a = { ... }
                        local origin, dir = a[1], a[2]
                        if typeof(origin) == "Vector3" and typeof(dir) == "Vector3" then
                            local len = dir.Magnitude
                            if len >= (S.minLen or 20) and (origin - cam.CFrame.Position).Magnitude <= (S.maxOrigin or 80) then
                                local toT = tgt.Position - origin
                                -- alcance INFINITO: estende o raio p/ sempre chegar no alvo
                                local newLen = math.max(len, toT.Magnitude + 30)
                                a[2] = toT.Unit * newLen
                                -- WALLBANG: raycast só contra o char do alvo (ignora paredes = tiro sempre conta)
                                if S.wallbang and tgt.Parent then
                                    local rp = RaycastParams.new()
                                    local okf = pcall(function() rp.FilterType = Enum.RaycastFilterType.Include end)
                                    if not okf then pcall(function() rp.FilterType = Enum.RaycastFilterType.Whitelist end) end
                                    rp.FilterDescendantsInstances = { tgt.Parent }
                                    a[3] = rp
                                end
                                return old(self, table.unpack(a))
                            end
                        end
                    end
                end
            end
            return old(self, ...)
        end)
    end)
    if not ok then warn("[Midnight Silent] Falha ao instalar o hook.") end
elseif not hookOK then
    warn("[Midnight Silent] Executor sem suporte a hook — Silent Aim indisponível (ESP funciona normal).")
end


    lbl.Text = label; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextColor3 = C.Dim; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local box = Instance.new("TextButton", h)
    box.Size = UDim2.new(1, 0, 0, 24); box.Position = UDim2.new(0, 0, 0, 18)
    box.AutoButtonColor = false; box.BackgroundColor3 = C.Card; box.BorderSizePixel = 0
    box.Text = tostring(CFG[key]); box.Font = Enum.Font.GothamBold; box.TextSize = 12; box.TextColor3 = C.Text
    corner(box, 6); stroke(box, C.Line, 1, 0.3)
    local idx = 1
    for i, o in ipairs(options) do if o == CFG[key] then idx = i end end
    local function refresh()
        for i, o in ipairs(options) do if o == CFG[key] then idx = i end end
        box.Text = tostring(CFG[key])
    end
    table.insert(dropdownRefreshers, refresh)
    table.insert(searchItems, { obj = h, label = tostring(label):lower(), tab = buildTab })
    box.MouseButton1Click:Connect(function()
        idx = idx % #options + 1
        CFG[key] = options[idx]; box.Text = tostring(CFG[key])
        tw(box, {BackgroundColor3 = C.Hover}, 0.08)
        task.delay(0.12, function() tw(box, {BackgroundColor3 = C.Card}, 0.12) end)
        if requestSave then requestSave() end
    end)
    box.MouseEnter:Connect(function() tw(box, {BackgroundColor3 = C.Hover}, 0.1) end)
    box.MouseLeave:Connect(function() tw(box, {BackgroundColor3 = C.Card}, 0.1) end)
    return h
end


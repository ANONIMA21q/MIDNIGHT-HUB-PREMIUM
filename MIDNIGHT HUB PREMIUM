-- Cria um toggle card
local function CreateToggle(parent, label, icon, key, order)
    local card = Instance.new("Frame", parent)
    card.Size = UDim2.new(1, -4, 0, 44)
    card.BackgroundColor3 = C.Card
    card.LayoutOrder = order or 0
    card.ZIndex = 12
    Corner(card, 10)
    Stroke(card, C.Border, 1)

    local iconL = Instance.new("TextLabel", card)
    iconL.Size = UDim2.new(0, 38, 1, 0)
    iconL.BackgroundTransparency = 1
    iconL.Text = icon or "•"
    iconL.Font = Enum.Font.GothamBold
    iconL.TextSize = 18
    iconL.TextColor3 = C.Accent
    iconL.ZIndex = 13

    local lbl = Instance.new("TextLabel", card)
    lbl.Size = UDim2.new(1, -100, 1, 0)
    lbl.Position = UDim2.new(0, 38, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = C.TextMain
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 13

    -- Pill (toggle visual)
    local pillBG = Instance.new("Frame", card)
    pillBG.Size = UDim2.fromOffset(46, 24)
    pillBG.Position = UDim2.new(1, -56, 0.5, -12)
    pillBG.BackgroundColor3 = CFG[key] and C.ON or C.OFF
    pillBG.ZIndex = 13
    Corner(pillBG, 12)

    local pillDot = Instance.new("Frame", pillBG)
    pillDot.Size = UDim2.fromOffset(18, 18)
    pillDot.Position = CFG[key] and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    pillDot.BackgroundColor3 = C.White
    pillDot.ZIndex = 14
    Corner(pillDot, 9)

    local function refreshToggle()
        local on = CFG[key]
        Tween(pillBG, {BackgroundColor3 = on and C.ON or C.OFF}, 0.15)
        Tween(pillDot, {Position = on and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)}, 0.15)
        lbl.TextColor3 = on and C.TextMain or C.TextDim
    end

    card.InputBegan:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if not AccessGranted then return end
        CFG[key] = not CFG[key]
        refreshToggle()
        Tween(card, {BackgroundColor3 = Color3.fromRGB(22, 22, 34)}, 0.08)
        task.delay(0.1, function() Tween(card, {BackgroundColor3 = C.Card}, 0.12) end)
    end)

    return card
end

-- Cria um botão de ação
local function CreateButton(parent, label, icon, callback, order)
    local card = Instance.new("TextButton", parent)
    card.Size = UDim2.new(1, -4, 0, 40)
    card.BackgroundColor3 = C.Card
    card.Font = Enum.Font.GothamBold
    card.TextSize = 13
    card.Text = (icon or "") .. "  " .. label
    card.TextColor3 = C.Accent
    card.LayoutOrder = order or 0
    card.ZIndex = 12
    Corner(card, 10)
    Stroke(card, C.Border, 1)

    card.MouseEnter:Connect(function()
        Tween(card, {BackgroundColor3 = Color3.fromRGB(22, 22, 36)}, 0.12)
        Tween(card, {TextColor3 = C.White}, 0.12)
    end)
    card.MouseLeave:Connect(function()
        Tween(card, {BackgroundColor3 = C.Card}, 0.12)
        Tween(card, {TextColor3 = C.Accent}, 0.12)
    end)
    card.MouseButton1Click:Connect(function()
        if not AccessGranted then return end
        if callback then callback() end
        Tween(card, {BackgroundColor3 = C.AccentDim}, 0.08)
        task.delay(0.12, function() Tween(card, {BackgroundColor3 = C.Card}, 0.14) end)
    end)
    return card
end


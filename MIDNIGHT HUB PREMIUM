end

local function Radio(parent, label, key, order)
    local row = Instance.new("TextButton", parent)
    row.Size = UDim2.new(1, 0, 0, 22); row.LayoutOrder = order or 0
    row.BackgroundTransparency = 1; row.AutoButtonColor = false; row.Text = ""

    local circle = Instance.new("Frame", row)
    circle.Size = UDim2.fromOffset(16, 16); circle.Position = UDim2.new(0, 0, 0.5, -8)
    circle.BackgroundColor3 = CFG[key] and C.Accent or C.Off
    circle.BorderSizePixel = 0; corner(circle, 8)
    local ring = stroke(circle, CFG[key] and C.Accent or C.Line, 1.5, 0)

    local dotIn = Instance.new("Frame", circle)
    dotIn.Size = UDim2.fromOffset(6, 6); dotIn.Position = UDim2.new(0.5, -3, 0.5, -3)
    dotIn.BackgroundColor3 = C.White; dotIn.BorderSizePixel = 0; corner(dotIn, 3)
    dotIn.Visible = CFG[key]

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -26, 1, 0); lbl.Position = UDim2.new(0, 26, 0, 0)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 13
    lbl.TextColor3 = CFG[key] and C.Text or C.Dim
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local function refresh()
        local on = CFG[key]
        tw(circle, {BackgroundColor3 = on and C.Accent or C.Off}, 0.12)
        tw(ring, {Color = on and C.Accent or C.Line}, 0.12)
        dotIn.Visible = on
        tw(lbl, {TextColor3 = on and C.Text or C.Dim}, 0.12)
    end
    row.MouseButton1Click:Connect(function() CFG[key] = not CFG[key]; refresh() end)
    return row
end

local function Slider(parent, label, key, minV, maxV, decimals, order)
    local h = Instance.new("Frame", parent)
    h.Size = UDim2.new(1, 0, 0, 40); h.LayoutOrder = order or 0
    h.BackgroundTransparency = 1

    local lbl = Instance.new("TextLabel", h)
    lbl.Size = UDim2.new(1, -70, 0, 18); lbl.BackgroundTransparency = 1
    lbl.Text = label; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12
    lbl.TextColor3 = C.Dim; lbl.TextXAlignment = Enum.TextXAlignment.Left

    local val = Instance.new("TextLabel", h)
    val.Size = UDim2.new(0, 70, 0, 18); val.Position = UDim2.new(1, -70, 0, 0)
    val.BackgroundTransparency = 1; val.Font = Enum.Font.GothamBold; val.TextSize = 12
    val.TextColor3 = C.Dim; val.TextXAlignment = Enum.TextXAlignment.Right

    local track = Instance.new("Frame", h)
    track.Size = UDim2.new(1, 0, 0, 8); track.Position = UDim2.new(0, 0, 0, 24)
    track.BackgroundColor3 = C.Card; track.BorderSizePixel = 0; corner(track, 4)

    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3 = C.Accent; fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BorderSizePixel = 0; corner(fill, 4); gradient(fill, C.Accent, C.Accent2, 0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.fromOffset(14, 14); knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0, 0, 0.5, 0); knob.BackgroundColor3 = C.White
    knob.BorderSizePixel = 0; corner(knob, 7)

    local function fmt(v)
        if decimals and decimals > 0 then local m = 10 ^ decimals; return math.floor(v * m + 0.5) / m end
        return math.floor(v + 0.5)
    end
    local function update()
        local pct = math.clamp((CFG[key] - minV) / (maxV - minV), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0); knob.Position = UDim2.new(pct, 0, 0.5, 0)
        val.Text = tostring(fmt(CFG[key])) .. "/" .. tostring(fmt(maxV))
    end
    update()

    local dragging = false
    local function setX(x)
        local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local v = minV + (maxV - minV) * rel
        if decimals and decimals > 0 then local m = 10 ^ decimals; v = math.floor(v * m + 0.5) / m else v = math.floor(v + 0.5) end
        CFG[key] = v; update()
    end
    track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; setX(i.Position.X) end end)
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then setX(i.Position.X) end end)
    return h
end

local function Dropdown(parent, label, key, options, order)
    local h = Instance.new("Frame", parent)
    h.Size = UDim2.new(1, 0, 0, 44); h.LayoutOrder = order or 0
    h.BackgroundTransparency = 1

    local lbl = Instance.new("TextLabel", h)
    lbl.Size = UDim2.new(1, 0, 0, 16); lbl.BackgroundTransparency = 1
    lbl.Text = label; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12
    lbl.TextColor3 = C.Dim; lbl.TextXAlignment = Enum.TextXAlignment.Left

    local box = Instance.new("TextButton", h)
    box.Size = UDim2.new(1, 0, 0, 24); box.Position = UDim2.new(0, 0, 0, 18)
    box.AutoButtonColor = false; box.BackgroundColor3 = C.Card; box.BorderSizePixel = 0
    box.Text = tostring(CFG[key]); box.Font = Enum.Font.GothamBold; box.TextSize = 12
    box.TextColor3 = C.Text; corner(box, 6); stroke(box, C.Line, 1, 0.3)

    local idx = 1
    for i, o in ipairs(options) do if o == CFG[key] then idx = i end end
    box.MouseButton1Click:Connect(function()
        idx = idx % #options + 1
        CFG[key] = options[idx]; box.Text = tostring(CFG[key])
        tw(box, {BackgroundColor3 = C.Hover}, 0.08)
        task.delay(0.12, function() tw(box, {BackgroundColor3 = C.Card}, 0.12) end)
    end)
    box.MouseEnter:Connect(function() tw(box, {BackgroundColor3 = C.Hover}, 0.1) end)
    box.MouseLeave:Connect(function() tw(box, {BackgroundColor3 = C.Card}, 0.1) end)
    return h
end


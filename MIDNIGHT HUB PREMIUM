local R15Bones = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
}
local R6Bones = {
    {"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},
    {"Torso","Left Leg"},{"Torso","Right Leg"},
}
local MAXB = #R15Bones

local function healthColor(p)
    p = math.clamp(p, 0, 1)
    if p > 0.5 then return Color3.new((1 - p) * 2, 1, 0) else return Color3.new(1, p * 2, 0) end
end

local cache = {}
local function addESP(plr)
    if plr == LP or not hasDrawing then return end
    local d = { Name = newText(), Health = newText(), Box = newBox(), Tracer = newLine(), Bones = {} }
    for i = 1, MAXB do d.Bones[i] = newLine() end
    cache[plr] = d
end
local function removeESP(plr)
    local d = cache[plr]; if not d then return end
    pcall(function() d.Name:Remove() end); pcall(function() d.Health:Remove() end)
    pcall(function() d.Box:Remove() end); pcall(function() d.Tracer:Remove() end)
    for _, l in pairs(d.Bones) do pcall(function() l:Remove() end) end
    cache[plr] = nil
end
for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
Players.PlayerAdded:Connect(addESP)
Players.PlayerRemoving:Connect(removeESP)

local function hideAll(d)
    d.Name.Visible = false; d.Health.Visible = false; d.Box.Visible = false; d.Tracer.Visible = false
    for _, l in pairs(d.Bones) do l.Visible = false end
end

-- ESP loop
if hasDrawing then
    RunService.RenderStepped:Connect(function()
        -- ESP
        if not AccessGranted or not CFG.ESP then
            for _, d in pairs(cache) do hideAll(d) end; return
        end
        local vp = Camera.ViewportSize
        for plr, d in pairs(cache) do
            hideAll(d)
            local char = plr.Character; if not char then continue end
            local hum = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
            if not hum or not hrp or hum.Health <= 0 then continue end
            if CFG.TeamCheck and plr.Team and LP.Team and plr.Team == LP.Team then continue end

            local rp, on = Camera:WorldToViewportPoint(hrp.Position)
            if not on or rp.Z <= 0 then continue end

            local head = char:FindFirstChild("Head")
            local hp = head and select(1, Camera:WorldToViewportPoint(head.Position)) or rp

            if CFG.Name then
                local txt = plr.Name
                if CFG.Distance then
                    txt = txt .. "  [" .. math.floor((Camera.CFrame.Position - hrp.Position).Magnitude) .. "m]"
                end
                d.Name.Text = txt
                d.Name.Position = Vector2.new(rp.X, (hp.Y or rp.Y) - 30)
                d.Name.Visible = true
            end
            if CFG.Health then
                local pct = hum.Health / math.max(hum.MaxHealth, 1)
                d.Health.Color = healthColor(pct)
                d.Health.Text = "HP " .. math.floor(hum.Health)
                d.Health.Position = Vector2.new(rp.X, (hp.Y or rp.Y) - 15)
                d.Health.Visible = true
            end
            if CFG.Box and head then
                local h = math.abs(hp.Y - rp.Y) * 2.4
                local w = h * 0.55
                d.Box.Size = Vector2.new(w, h)
                d.Box.Position = Vector2.new(hp.X - w / 2, hp.Y - h * 0.12)
                d.Box.Visible = true
            end
            if CFG.Skeleton then
                local bones = char:FindFirstChild("UpperTorso") and R15Bones or R6Bones
                for i, bn in ipairs(bones) do
                    local a = char:FindFirstChild(bn[1]); local b = char:FindFirstChild(bn[2])
                    if a and b then
                        local pa, va = Camera:WorldToViewportPoint(a.Position)
                        local pb, vb = Camera:WorldToViewportPoint(b.Position)
                        if va and vb and pa.Z > 0 and pb.Z > 0 then
                            d.Bones[i].From = Vector2.new(pa.X, pa.Y)
                            d.Bones[i].To = Vector2.new(pb.X, pb.Y)
                            d.Bones[i].Visible = true
                        end
                    end
                end
            end
            if CFG.Tracer then
                d.Tracer.From = Vector2.new(vp.X / 2, vp.Y)
                d.Tracer.To = Vector2.new(rp.X, rp.Y)
                d.Tracer.Visible = true
            end
        end
    end)
end

-- =====================================================================
-- WALL CHECK (raycast)
-- =====================================================================
local function isVisible(char, part)
    local ok, result = pcall(function()
        local origin = Camera.CFrame.Position
        local dir = part.Position - origin
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = { char, LP.Character }
        return workspace:Raycast(origin, dir, params)
    end)
    if not ok then return true end -- se raycast falhar, considera visível
    return result == nil
end


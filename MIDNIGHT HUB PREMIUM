-- ===================== BUSCA DE OPÇÕES =====================
local function runSearch(q)
    q = tostring(q or ""):lower():gsub("^%s+", ""):gsub("%s+$", "")
    local activeHas, firstTab = false, nil
    for _, it in ipairs(searchItems) do
        local show = (q == "") or (it.label:find(q, 1, true) ~= nil)
        pcall(function() it.obj.Visible = show end)
        if show and q ~= "" then
            if not firstTab then firstTab = it.tab end
            if it.tab == activeTab then activeHas = true end
        end
    end
    if q ~= "" and not activeHas and firstTab then selectTab(firstTab) end
end
searchBox:GetPropertyChangedSignal("Text"):Connect(function() runSearch(searchBox.Text) end)


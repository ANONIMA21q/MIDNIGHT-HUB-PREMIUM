-- SALVAR / CARREGAR CONFIG (persistente entre sessões) + AUTO-SAVE
-- =====================================================================
local HttpService = game:GetService("HttpService")
local CFG_FILE = "midnight_silent_config.json"
local function col2t(c) return { math.floor(c.R * 255 + 0.5), math.floor(c.G * 255 + 0.5), math.floor(c.B * 255 + 0.5) } end
local function t2col(t) return Color3.fromRGB(t[1] or 255, t[2] or 255, t[3] or 255) end

local function saveCfg()
    if not writefile then return end
    pcall(function()
        local data = {
            CFG = CFG,
            Theme = {
                Accent = col2t(C.Accent), BG = col2t(C.BG), Text = col2t(C.Text),
                Esp = col2t(DRAW), Fov = col2t(fovStroke.Color),
            },
        }
        writefile(CFG_FILE, HttpService:JSONEncode(data))
    end)
end

-- auto-save com debounce (junta várias mudanças rápidas num único write)
local saveQueued = false
requestSave = function()
    if not writefile or saveQueued then return end
    saveQueued = true
    task.delay(1.0, function() saveQueued = false; saveCfg() end)
end

local function loadCfg()
    if not (readfile and isfile) then return false end
    local raw
    local ok = pcall(function() if isfile(CFG_FILE) then raw = readfile(CFG_FILE) end end)
    if not ok or not raw or raw == "" then return false end
    local data
    local ok2 = pcall(function() data = HttpService:JSONDecode(raw) end)
    if not ok2 or type(data) ~= "table" then return false end
    if type(data.CFG) == "table" then
        for k, v in pairs(data.CFG) do
            if CFG[k] ~= nil and type(CFG[k]) == type(v) then CFG[k] = v end
        end
    end
    local th = data.Theme
    if type(th) == "table" then
        pcall(function() if th.BG then setBgColor(t2col(th.BG)) end end)
        pcall(function() if th.Text then setTextColor(t2col(th.Text)) end end)
        pcall(function() if th.Accent then setAccent(t2col(th.Accent)) end end)
        pcall(function() if th.Esp then setEspColor(t2col(th.Esp)) end end)
        pcall(function() if th.Fov then setFovColor(t2col(th.Fov)) end end)
    end
    pcall(function() setSharp(CFG.Sharp) end)
    -- reflete os valores carregados na UI
    for _, fn in ipairs(radioRefreshers) do pcall(fn) end
    for _, fn in ipairs(sliderUpdaters) do pcall(fn) end
    for _, fn in ipairs(dropdownRefreshers) do pcall(fn) end
    if CFG.BgImage and CFG.BgImage ~= "" then pcall(function() setBgImage(CFG.BgImage, nil) end) end
    return true
end


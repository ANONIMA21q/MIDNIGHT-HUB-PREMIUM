            main.Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset, main.Position.Y.Scale, main.Position.Y.Offset)
            main.BackgroundTransparency = 1
            Tween(main, {BackgroundTransparency = 0}, 0.18)
        end
    end
end)


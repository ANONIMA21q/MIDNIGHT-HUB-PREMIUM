-- Cria slider de valor (FOV)
local function CreateSlider(parent, label, icon, cfgKey, minVal, maxVal, order)
    local card = Instance.new("Frame", parent)
    card.Size = UDim2.new(1, -4, 0, 56)
    card.BackgroundColor3 = C.Card
    card.LayoutOrder = order or 0
    card.ZIndex = 12
    Corner(card, 10)
    Stroke(card, C.Border, 1)

    local iconL = Instance.new("TextLabel", card)
    iconL.Size = UDim2.new(0, 38, 0, 24)
    iconL.Position = UDim2.new(0, 0, 0, 4)
    iconL.BackgroundTransparency = 1
    iconL.Text = icon or "•"
    iconL.Font = Enum.Font.GothamBold
    iconL.TextSize = 18
    iconL.TextColor3 = C.Accent
    iconL.ZIndex = 13

    local lbl = Instance.new("TextLabel", card)
    lbl.Size = UDim2.new(0, 200, 0, 24)
    lbl.Position = UDim2.new(0, 38, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = C.TextMain
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 13

    local valLbl = Instance.new("TextLabel", card)
    valLbl.Size = UDim2.new(0, 50, 0, 24)
    valLbl.Position = UDim2.new(1, -54, 0, 4)
    valLbl.BackgroundTransparency = 1
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 13
    valLbl.TextColor3 = C.Accent
    valLbl.ZIndex = 13

    local track = Instance.new("Frame", card)
    track.Size = UDim2.new(1, -20, 0, 6)
    track.Position = UDim2.new(0, 10, 1, -16)
    track.BackgroundColor3 = C.Border
    track.ZIndex = 13
    Corner(track, 3)

    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3 = C.Accent
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.ZIndex = 14
    Corner(fill, 3)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.fromOffset(12, 12)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.BackgroundColor3 = C.White
    knob.ZIndex = 15
    Corner(knob, 6)

    local function updateVisual()
        local pct = (CFG[cfgKey] - minVal) / (maxVal - minVal)
        pct = math.clamp(pct, 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, 0, 0.5, 0)
        lbl.Text = label
        valLbl.Text = tostring(CFG[cfgKey])
    end
    updateVisual()

    local dragging = false
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if not AccessGranted then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement then
            local tAbs = track.AbsolutePosition
            local tSz = track.AbsoluteSize
            local rel = math.clamp((i.Position.X - tAbs.X) / tSz.X, 0, 1)
            CFG[cfgKey] = math.floor(minVal + (maxVal - minVal) * rel)
            updateVisual()
        end
    end)

    return card
end

-- Cria seletor de valor (AimKey)
local function CreateSelector(parent, label, icon, options, getVal, setVal, order)
    local card = Instance.new("Frame", parent)
    card.Size = UDim2.new(1, -4, 0, 44)
    card.BackgroundColor3 = C.Card
    card.LayoutOrder = order or 0
    card.ZIndex = 12
    Corner(card, 10)
    Stroke(card, C.Border, 1)

    local iconL = Instance.new("TextLabel", card)
    iconL.Size = UDim2.new(0, 38, 1, 0)
    iconL.BackgroundTransparency = 1
    iconL.Text = icon or "•"
    iconL.Font = Enum.Font.GothamBold
    iconL.TextSize = 18
    iconL.TextColor3 = C.Accent
    iconL.ZIndex = 13

    local lbl = Instance.new("TextLabel", card)
    lbl.Size = UDim2.new(1, -140, 1, 0)
    lbl.Position = UDim2.new(0, 38, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = C.TextMain
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 13

    for i, opt in ipairs(options) do
        local btn = Instance.new("TextButton", card)
        btn.Size = UDim2.fromOffset(52, 26)
        btn.Position = UDim2.new(1, -10 - (56 * (#options - i + 1)), 0.5, -13)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 12
        btn.Text = opt
        btn.ZIndex = 13
        Corner(btn, 7)

        local function refreshSel()
            local cur = getVal()
            btn.BackgroundColor3 = (cur == opt) and C.AccentDim or C.Border
            btn.TextColor3 = (cur == opt) and C.White or C.TextDim
        end
        refreshSel()

        btn.MouseButton1Click:Connect(function()
            if not AccessGranted then return end
            setVal(opt)
            -- refresh all
            for _, b in ipairs(card:GetChildren()) do
                if b:IsA("TextButton") then
                    b.BackgroundColor3 = (getVal() == b.Text) and C.AccentDim or C.Border
                    b.TextColor3 = (getVal() == b.Text) and C.White or C.TextDim
                end
            end
        end)
    end

    return card
end

